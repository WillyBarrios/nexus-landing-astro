    </div>

    <div class="team-grid">
        <article class="team-card">
            <div class="photo-slot">
                <img src="/assets/diana.jpg" alt="Diana Avendaño" />
            </div>
            <h3>Diana Avendaño</h3>
            <p>CEO y CDO</p>
        </article>
        <article class="team-card">
            <div class="photo-slot">
                <img src="/assets/deickar.jpg" alt="Deickar Paz" />
            </div>
            <h3>Deickar Paz</h3>
            <p>CEO, PM y Dev</p>
        </article>
        <article class="team-card">
            <div class="photo-slot">
                <img src="/assets/willy.jpg" alt="Willy Barrios" />
            </div>
            <h3>Willy Barrios</h3>
            <p>CEO, CTO y Dev</p>
        </article>
        <article class="team-card">
            <div class="photo-slot">
                <img src="/assets/estefani.jpg" alt="Estefani Osorio" />
            </div>
            <h3>Estefani Osorio</h3>
            <p>Desarrollador Frontend</p>
        </article>
        <article class="team-card">
            <div class="photo-slot">
                <img src="/assets/andrea.jpg" alt="Andrea Porras" />
